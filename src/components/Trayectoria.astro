---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const experiences = [
  {
    company: 'Minsait(Indra)',
    position: t('experience.job1'),
    period: lang === 'es' ? '2026-05 - Actualidad' : '2026-05 - Present',
    current: true,
    description: t('experience.job1Desc'),
    achievements: [],
  },
  {
    company: 'Minsait(Indra)',
    position: t('experience.job2'),
    period: lang === 'es' ? '2024 - 2025' : '2024 - 2025',
    current: false,
    description: t('experience.job2Desc'),
    achievements: [],
  },
  {
    company: 'CPR de Jerez de los Caballeros',
    position: t('experience.job3'),
    period: lang === 'es' ? '2023' : '2023',
    current: false,
    description: t('experience.job3Desc'),
    achievements: [],
  }
];

const education = [
  {
    company: 'Ies Castelar',
    position: t('titles.daw'),
    period: lang === 'es' ? '2024 - Actualidad' : '2024 - Present',
    current: true,
    description: '',
    achievements: [],
  },
  {
    company: 'Ies Ildefonso Serrano',
    position: t('titles.smr'),
    period: lang === 'es' ? '2022 - 2023' : '2022 - 2023',
    current: false,
    description: t('titles.smrDesc'),
    achievements: [],
  },
  {
    company: 'Ies Eugenio Hermoso',
    position: t('titles.eso'),
    period: lang === 'es' ? '2017 - 2021' : '2017 - 2021',
    current: false,
    description: '',
    achievements: [],
  }
];
---

<section id="trayectoria" class="py-12 md:py-20 bg-gradient-to-br from-gray-50 to-purple-50">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="section-title text-center mb-12 md:mb-16" data-aos="fade-up">{t('resume.title')}</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-8 lg:gap-16">
        
        <!-- Columna Experiencia -->
        <div data-aos="fade-right">
          <h3 class="text-2xl md:text-3xl font-bold text-secondary mb-8 flex items-center gap-3">
            <span class="p-2 bg-blue-100 text-primary rounded-lg">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </span>
            {t('resume.experience')}
          </h3>
          
          <div class="relative pl-6 md:pl-8 border-l-2 border-primary/30 space-y-10">
            {experiences.map((exp, idx) => (
              <div class="relative">
                <!-- Timeline Dot -->
                <div class="absolute -left-[35px] md:-left-[41px] top-1.5 w-4 h-4 bg-primary rounded-full border-4 border-white shadow"></div>
                
                <div class="glass p-5 md:p-6 rounded-xl shadow-md card-hover relative group">
                  {exp.current && (
                    <div class="absolute -top-3 -right-3 px-3 py-1 bg-gradient-to-r from-green-400 to-green-600 text-white text-xs font-bold rounded-full shadow animate-pulse">
                      {lang === 'es' ? 'Actual' : 'Current'}
                    </div>
                  )}
                  
                  <div class="flex flex-col sm:flex-row items-start gap-3 mb-2">
                    <div class="text-2xl hidden sm:block mt-1">{exp.logo}</div>
                    <div class="flex-1 w-full">
                      <h4 class="text-lg md:text-xl font-bold text-secondary">{exp.position}</h4>
                      <p class="text-primary font-semibold text-sm md:text-base">{exp.company}</p>
                    </div>
                  </div>
                  
                  <span class="inline-flex items-center gap-1 text-gray-500 font-medium text-xs mb-3">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    {exp.period}
                  </span>
                  
                  {exp.description && (
                    <p class="text-sm text-gray-600 leading-relaxed group-hover:text-gray-900 transition-colors">{exp.description}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Columna Formación -->
        <div data-aos="fade-left">
          <h3 class="text-2xl md:text-3xl font-bold text-secondary mb-8 flex items-center gap-3">
            <span class="p-2 bg-purple-100 text-primary rounded-lg">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
            </span>
            {t('resume.education')}
          </h3>
          
          <div class="relative pl-6 md:pl-8 border-l-2 border-purple-400/30 space-y-10">
            {education.map((item, idx) => (
              <div class="relative">
                <!-- Timeline Dot -->
                <div class="absolute -left-[35px] md:-left-[41px] top-1.5 w-4 h-4 bg-purple-500 rounded-full border-4 border-white shadow"></div>
                
                <div class="glass p-5 md:p-6 rounded-xl shadow-md card-hover relative group">
                  {item.current && (
                    <div class="absolute -top-3 -right-3 px-3 py-1 bg-gradient-to-r from-purple-400 to-purple-600 text-white text-xs font-bold rounded-full shadow animate-pulse">
                      {lang === 'es' ? 'Actual' : 'Current'}
                    </div>
                  )}
                  
                  <div class="flex flex-col sm:flex-row items-start gap-3 mb-2">
                    <div class="text-2xl hidden sm:block mt-1">{item.logo}</div>
                    <div class="flex-1 w-full">
                      <h4 class="text-lg md:text-xl font-bold text-secondary">{item.position}</h4>
                      <p class="text-purple-600 font-semibold text-sm md:text-base">{item.company}</p>
                    </div>
                  </div>
                  
                  <span class="inline-flex items-center gap-1 text-gray-500 font-medium text-xs mb-3">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    {item.period}
                  </span>
                  
                  {item.description && (
                    <p class="text-sm text-gray-600 leading-relaxed group-hover:text-gray-900 transition-colors">{item.description}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>